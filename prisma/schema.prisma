model Expense {
  id String @id @default(cuid())

  expenseDate   DateTime
  description   String
  reference     String?
  invoiceNumber String?

  categoryId String
  category   ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

