  @@index([status])
  @@index([costCenter])
  @@index([categoryId])
  @@index([vendorId])
  @@index([maintenanceEventId])
  @@index([sparePartId])
  @@index([employeeId])
}

model BarCategory {
  id        String  @id @default(cuid())
  name      String  @db.VarChar(80)
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  products BarProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name])
  @@index([isActive, sortOrder])
}

model BarProduct {
  id String @id @default(cuid())

  categoryId String
  category   BarCategory @relation(fields: [categoryId], references: [id])

  name String         @db.VarChar(120)
  type BarProductType @default(OTHER)
  sku  String?        @db.VarChar(60)

  salePriceCents Int
  costPriceCents Int?
  vatRate        Decimal @default(21.00) @db.Decimal(5, 2)

  controlsStock Boolean @default(true)
  currentStock  Decimal @default(0) @db.Decimal(12, 3)
  minStock      Decimal @default(0) @db.Decimal(12, 3)

  unitLabel String? @db.VarChar(30)
  isActive  Boolean @default(true)

  staffEligible   Boolean @default(false)
  staffPriceCents Int?

  stockMovements      BarStockMovement[]
  taskItems           FulfillmentTaskItem[]
  promotions          BarPromotion[]
  purchaseItems       BarStockPurchaseItem[]
  expenseRestockItems ExpenseBarRestockItem[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  barSaleItems BarSaleItem[]

  @@unique([sku])
  @@index([categoryId, isActive])
  @@index([type, isActive])
}

model BarStockMovement {
  id String @id @default(cuid())

  productId String
  product   BarProduct @relation(fields: [productId], references: [id])

  type   StockMovementType
  reason StockMovementReason

  quantity    Decimal  @db.Decimal(12, 3)
  stockBefore Decimal? @db.Decimal(12, 3)
  stockAfter  Decimal? @db.Decimal(12, 3)

  unitCostCents Int?
  notes         String? @db.Text

  sourceType String? @db.VarChar(40)
  sourceId   String? @db.VarChar(120)

  userId String?
  user   User?   @relation("BarStockMovementUser", fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([productId, createdAt])
  @@index([reason, createdAt])
  @@index([sourceType, sourceId])
}

model BarPromotion {
  id String @id @default(cuid())

  productId String
  product   BarProduct @relation(fields: [productId], references: [id])

  name String @db.VarChar(120)

  type BarPromotionType

  // FIXED_TOTAL_FOR_QTY
  exactQty        Int?
  fixedTotalCents Int?

  // BUY_X_PAY_Y
  buyQty Int?
  payQty Int?

  isActive Boolean @default(true)

  startsAt DateTime?
  endsAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, isActive])
}

model BarStockPurchase {
  id String @id @default(cuid())

  expenseId String?
  expense   Expense? @relation(fields: [expenseId], references: [id])

  status       BarStockPurchaseStatus @default(RECEIVED)
  purchaseDate DateTime               @default(now())
  notes        String?                @db.Text

  totalCents Int @default(0)

  items BarStockPurchaseItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([purchaseDate, status])
  @@index([expenseId])
}

model BarStockPurchaseItem {
  id String @id @default(cuid())

  purchaseId String
  purchase   BarStockPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  productId String
  product   BarProduct @relation(fields: [productId], references: [id])

  quantity      Decimal @db.Decimal(12, 3)
  unitCostCents Int
  totalCents    Int

  createdAt DateTime @default(now())

  @@index([purchaseId])
  @@index([productId])
}

model ExpenseBarRestock {
  id String @id @default(cuid())

  expenseId String  @unique
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  appliedAt       DateTime @default(now())
  appliedByUserId String?
  appliedByUser   User?    @relation("ExpenseBarRestockAppliedBy", fields: [appliedByUserId], references: [id], onDelete: SetNull)

  note String?

  items ExpenseBarRestockItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([appliedAt])
  @@index([appliedByUserId])
}

model BarSale {
  id String @id @default(cuid())

  paymentId String?  @unique
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  shiftSessionId String?
  shiftSession   ShiftSession? @relation(fields: [shiftSessionId], references: [id], onDelete: SetNull)

  soldAt       DateTime @default(now())
  soldByUserId String?
  soldByUser   User?    @relation("BarSaleSoldByUser", fields: [soldByUserId], references: [id], onDelete: SetNull)

  staffMode Boolean @default(false)
  note      String?

  totalRevenueCents Int @default(0)
  totalCostCents    Int @default(0)
  totalMarginCents  Int @default(0)

  items BarSaleItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([soldAt])
  @@index([staffMode, soldAt])
  @@index([soldByUserId])
}

model BarSaleItem {
  id String @id @default(cuid())

  saleId String
  sale   BarSale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId String
  product   BarProduct @relation(fields: [productId], references: [id])

  quantity Decimal @db.Decimal(12, 3)

  unitPriceCents Int
  revenueCents   Int

  unitCostCents Int?
  costCents     Int?

  marginCents Int?

  promotionLabel String?

  createdAt DateTime @default(now())

  @@index([saleId])
  @@index([productId])
}

model ExpenseBarRestockItem {
  id String @id @default(cuid())

  restockId String
  restock   ExpenseBarRestock @relation(fields: [restockId], references: [id], onDelete: Cascade)

  productId String
  product   BarProduct @relation(fields: [productId], references: [id])

  quantity       Decimal @db.Decimal(12, 3)
  unitCostCents  Int?
  totalCostCents Int?

  createdAt DateTime @default(now())

  @@index([restockId])
  @@index([productId])
}

model FulfillmentTask {
  id String @id @default(cuid())

  reservationId String?
  reservation   Reservation? @relation(fields: [reservationId], references: [id])

  source FulfillmentSource @default(STORE)
  type   FulfillmentType
  area   FulfillmentArea   @default(BAR)
  status FulfillmentStatus @default(PENDING)

  title            String  @db.VarChar(140)
  customerNameSnap String? @db.VarChar(120)

  paid            Boolean @default(false)
  paidAmountCents Int?    @default(0)

  scheduledFor      DateTime?
  deliveredAt       DateTime?
  deliveredByUserId String?
  deliveredByUser   User?     @relation("FulfillmentDeliveredByUser", fields: [deliveredByUserId], references: [id])

  returnedAt       DateTime?
  returnedByUserId String?
  returnedByUser   User?     @relation("FulfillmentReturnedByUser", fields: [returnedByUserId], references: [id])

  notes String? @db.Text

  items            FulfillmentTaskItem[]
  assetAssignments FulfillmentAssetAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reservationId])
  @@index([area, status, scheduledFor])
  @@index([type, status])
}

model FulfillmentTaskItem {
  id String @id @default(cuid())

  taskId String
  task   FulfillmentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  barProductId String?
  barProduct   BarProduct? @relation(fields: [barProductId], references: [id])

  reservationItemId String?
  kind              String  @db.VarChar(30) // BAR_PRODUCT | EXTRA

  nameSnap String  @db.VarChar(140)
  quantity Decimal @db.Decimal(12, 3)

  deliveredAt DateTime?
  returnedAt  DateTime?

  assetAssignments FulfillmentAssetAssignment[]

  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([barProductId])
  @@index([reservationItemId])
}

model RentalAsset {
  id String @id @default(cuid())

  type     RentalAssetType
  name     String            @db.VarChar(120)
  code     String?           @db.VarChar(60) // Ej: GOPRO-01, WET-M-03
  size     String?           @db.VarChar(20) // Ej: XS, S, M, L, XL
  status   RentalAssetStatus @default(AVAILABLE)
  notes    String?           @db.Text
  isActive Boolean           @default(true)

  assignments FulfillmentAssetAssignment[]

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  rentalAssetIncidents RentalAssetIncident[]

  @@unique([code])
  @@index([type, status])
  @@index([isActive, status])
  @@index([type, size, status])
}

model RentalAssetIncident {
  id String @id @default(cuid())

  rentalAssetId String
  rentalAsset   RentalAsset @relation(fields: [rentalAssetId], references: [id])

  type RentalAssetIncidentType
  note String?                 @db.Text

  openedAt       DateTime @default(now())
  openedByUserId String?
  openedByUser   User?    @relation("RentalAssetIncidentOpenedByUser", fields: [openedByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rentalAssetId, openedAt])
  @@index([type, openedAt])
}

model FulfillmentAssetAssignment {
  id String @id @default(cuid())

  taskId String
  task   FulfillmentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  taskItemId String?
  taskItem   FulfillmentTaskItem? @relation(fields: [taskItemId], references: [id], onDelete: SetNull)

  rentalAssetId String
  rentalAsset   RentalAsset @relation(fields: [rentalAssetId], references: [id])

  assignedAt       DateTime @default(now())
  assignedByUserId String?
  assignedByUser   User?    @relation("FulfillmentAssignedByUser", fields: [assignedByUserId], references: [id])

  returnedAt       DateTime?
  returnedByUserId String?
  returnedByUser   User?     @relation("FulfillmentReturnedAssetByUser", fields: [returnedByUserId], references: [id])

  returnOk    Boolean?
  returnNotes String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([taskItemId])
  @@index([rentalAssetId])
}

