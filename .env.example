DATABASE_URL=
SESSION_PASSWORD=

# URL pública de la app, usada en PDFs, reporting interno y enlaces firmados.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Zona horaria operativa del negocio.
BUSINESS_TZ=Europe/Madrid

# Si se guardan PDFs/autorizaciones/ficheros en S3 o compatible.
S3_PUBLIC_BASE_URL=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=

# Enlaces publicos firmados para bonos / contratos / pre-checkin.
CONTRACT_SIGNATURE_LINK_SECRET=
RESERVATION_CHECKIN_LINK_SECRET=
PASS_PORTAL_LINK_SECRET=
CONTRACT_SIGNATURE_LINK_TTL_MINUTES=45
RESERVATION_CHECKIN_LINK_TTL_MINUTES=4320
PASS_PORTAL_LINK_TTL_MINUTES=10080

# WhatsApp Business
# Proveedores soportados:
# - NONE
# - META_CLOUD_API
# - WEBHOOK
WHATSAPP_PROVIDER=NONE

# Meta Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE_CODE=es
WHATSAPP_PASS_TEMPLATE_NAME=
WHATSAPP_PASS_TEMPLATE_LANGUAGE_CODE=es
WHATSAPP_CONTRACT_TEMPLATE_NAME=
WHATSAPP_CONTRACT_TEMPLATE_LANGUAGE_CODE=es

# Webhook de Meta para estados delivered/read/failed
META_WEBHOOK_VERIFY_TOKEN=
META_WEBHOOK_APP_SECRET=

# Webhook propio / integrador
WHATSAPP_WEBHOOK_URL=
WHATSAPP_WEBHOOK_SECRET=
